<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0-windows</TargetFramework>
    <NoWarn>1705;1591</NoWarn>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AssemblyName>LucidGoldIndicator</AssemblyName>
    <RootNamespace>LucidGold.Indicator</RootNamespace>
    <Platforms>AnyCPU</Platforms>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <!-- Quantower picks this up to identify this DLL as an indicator -->
    <AlgoType>Indicator</AlgoType>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug'">
    <OutputPath>C:\Quantower\Settings\Scripts\Indicators\LucidGoldIndicator</OutputPath>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Release'">
    <OutputPath>C:\Quantower\Settings\Scripts\Indicators\LucidGoldIndicator</OutputPath>
  </PropertyGroup>
  <ItemGroup>
    <!-- Local SDK reference — verify path matches your Quantower installation -->
    <Reference Include="TradingPlatform.BusinessLayer">
      <HintPath>C:\Quantower\bin\TradingPlatform.BusinessLayer.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>
  <ItemGroup>

  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\LucidGoldCore\LucidGoldCore.csproj" />
  </ItemGroup>
</Project>
